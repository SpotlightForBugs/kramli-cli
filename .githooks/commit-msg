#!/usr/bin/env bash
# Strip Cursor co-author trailers that Cursor IDE injects automatically.
set -euo pipefail
msg_file="${1:?commit-msg hook requires path to commit message file}"
tmp="${msg_file}.scrubbed"
grep -viE '^co-authored-by:[[:space:]]*cursor[[:space:]]*<cursoragent@cursor\.com>[[:space:]]*$' "$msg_file" > "$tmp" || true
if [[ -s "$tmp" ]]; then
  mv "$tmp" "$msg_file"
else
  rm -f "$tmp"
fi
